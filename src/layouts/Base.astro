---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const { title, description = 'Developer insights on AI, specs, and documentation tooling.', ogImage } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? 'https://blog.mdspec.dev');
---

<!doctype html>
<html lang="en" class="h-full">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="canonical" href={canonicalURL} />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    {ogImage && <meta property="og:image" content={ogImage} />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" type="application/rss+xml" title="mdspec blog RSS feed" href="/rss.xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  </head>
  <body class="min-h-full flex flex-col bg-background">
    <!-- Prevent flash of wrong theme -->
    <script is:inline>
      (function () {
        const stored = localStorage.getItem('theme');
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        if (stored === 'dark' || (!stored && prefersDark)) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>

    <header class="sticky top-0 z-50 w-full border-b border-border/60 bg-background/80 backdrop-blur-sm">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex h-14 items-center justify-between">
          <a href="/" class="flex items-center gap-2.5 group">
            <span class="h-6 w-6 rounded bg-foreground flex items-center justify-center">
              <span class="text-background text-xs font-bold font-mono">M</span>
            </span>
            <span class="font-semibold text-sm tracking-tight">mdspec blog</span>
          </a>
          <nav class="flex items-center gap-1">
            <a
              href="/"
              class="px-3 py-1.5 text-sm text-muted-foreground hover:text-foreground transition-colors rounded-md hover:bg-accent"
            >Articles</a>
            <a
              href="https://mdspec.dev"
              class="px-3 py-1.5 text-sm text-muted-foreground hover:text-foreground transition-colors rounded-md hover:bg-accent"
            >mdspec →</a>
            <button
              id="theme-toggle"
              aria-label="Toggle dark mode"
              class="ml-1 p-1.5 rounded-md text-muted-foreground hover:text-foreground hover:bg-accent transition-colors"
            >
              <!-- Sun icon (shown in dark mode) -->
              <svg id="icon-sun" class="hidden w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="5"/>
                <path stroke-linecap="round" d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/>
              </svg>
              <!-- Moon icon (shown in light mode) -->
              <svg id="icon-moon" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/>
              </svg>
            </button>
          </nav>
        </div>
      </div>
    </header>

    <script is:inline>
      (function () {
        function updateIcons() {
          const isDark = document.documentElement.classList.contains('dark');
          document.getElementById('icon-sun').classList.toggle('hidden', !isDark);
          document.getElementById('icon-moon').classList.toggle('hidden', isDark);
        }
        updateIcons();
        document.getElementById('theme-toggle').addEventListener('click', function () {
          const isDark = document.documentElement.classList.toggle('dark');
          localStorage.setItem('theme', isDark ? 'dark' : 'light');
          updateIcons();
        });
      })();
    </script>

    <main class="flex-1">
      <slot />
    </main>

    <footer class="border-t border-border/60 mt-24">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
        <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
          <div class="flex items-center gap-2.5">
            <span class="h-5 w-5 rounded bg-foreground flex items-center justify-center">
              <span class="text-background text-[10px] font-bold font-mono">M</span>
            </span>
            <span class="text-sm font-medium">mdspec blog</span>
          </div>
          <p class="text-sm text-muted-foreground">
            Developer insights on specs, AI workflows, and documentation tooling. &nbsp;·&nbsp;
            <a href="https://mdspec.dev" class="underline underline-offset-4 hover:text-foreground transition-colors">mdspec.dev</a>
          </p>
        </div>
      </div>
    </footer>
  </body>
</html>
