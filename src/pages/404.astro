---
import Base from '../layouts/Base.astro';
---

<Base
  title="Page not found — mdspec blog"
  description="The page you're looking for doesn't exist."
>
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-32 text-center">
    <p class="text-xs font-mono font-medium tracking-widest text-muted-foreground uppercase mb-6">404</p>
    <h1 class="text-4xl sm:text-5xl font-bold tracking-tight text-foreground mb-4">
      Page not found
    </h1>
    <p class="text-lg text-muted-foreground mb-10 max-w-md mx-auto leading-relaxed">
      This page doesn't exist or may have been moved.
    </p>
    <a
      href="/"
      class="inline-flex items-center gap-2 text-sm font-medium bg-foreground text-background px-5 py-2.5 rounded-md hover:opacity-90 transition-opacity"
    >
      <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
      </svg>
      Back to articles
    </a>
  </div>
</Base>
