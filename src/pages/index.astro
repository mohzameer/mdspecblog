---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const posts = allPosts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 10);

const formatDate = (date: Date) =>
  new Intl.DateTimeFormat('en-US', { year: 'numeric', month: 'short', day: 'numeric' }).format(date);

const featured = posts[0];
const rest = posts.slice(1);
---

<Base
  title="mdspec blog — Developer insights on AI, specs & documentation"
  description="Practical articles for developers on managing markdown specs, AI-era documentation, and shipping without friction."
>
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Hero -->
    <section class="pt-16 pb-12 border-b border-border">
      <p class="text-xs font-mono font-medium tracking-widest text-muted-foreground uppercase mb-4">mdspec / blog</p>
      <h1 class="text-4xl sm:text-5xl font-bold tracking-tight text-foreground mb-4 max-w-2xl leading-[1.1]">
        Specs, docs &amp; AI.<br />Without the friction.
      </h1>
      <p class="text-lg text-muted-foreground max-w-xl leading-relaxed">
        Practical writing for developers navigating the new reality of AI-speed codebases, markdown sprawl, and documentation debt.
      </p>
    </section>

    <!-- Featured post -->
    {featured && (
      <section class="py-12 border-b border-border">
        <p class="text-xs font-mono font-medium tracking-widest text-muted-foreground uppercase mb-6">Featured</p>
        <div class="group relative">
          <a href={`/blog/${featured.slug}`} class="absolute inset-0 z-0" aria-label={featured.data.title}></a>
          <div class="grid sm:grid-cols-[1fr_auto] gap-6 items-start">
            <div>
              <div class="relative z-10 flex flex-wrap gap-2 mb-4">
                {featured.data.tags.map((tag) => (
                  <a
                    href={`/tag/${tag.toLowerCase().replace(/[\s\/]+/g, '-')}`}
                    class="inline-block whitespace-nowrap px-2.5 py-1 rounded-full text-xs font-medium leading-none bg-secondary text-secondary-foreground border border-border hover:border-foreground/40 transition-colors"
                  >
                    {tag}
                  </a>
                ))}
              </div>
              <h2 class="text-2xl sm:text-3xl font-bold tracking-tight text-foreground group-hover:text-muted-foreground transition-colors mb-3 leading-tight">
                {featured.data.title}
              </h2>
              <p class="text-muted-foreground leading-relaxed mb-4 max-w-2xl">
                {featured.data.description}
              </p>
              <div class="flex items-center gap-3 text-sm text-muted-foreground">
                <span>{featured.data.author}</span>
                <span class="w-1 h-1 rounded-full bg-border"></span>
                <time datetime={featured.data.pubDate.toISOString()}>{formatDate(featured.data.pubDate)}</time>
                {featured.data.readingTime && (
                  <>
                    <span class="w-1 h-1 rounded-full bg-border"></span>
                    <span>{featured.data.readingTime}</span>
                  </>
                )}
              </div>
            </div>
            <div class="shrink-0 self-start hidden sm:block">
              <div class="w-10 h-10 rounded-full border border-border flex items-center justify-center text-muted-foreground group-hover:border-foreground group-hover:text-foreground transition-colors">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                </svg>
              </div>
            </div>
          </div>
        </div>
      </section>
    )}

    <!-- Post grid -->
    {rest.length > 0 && (
      <section class="py-12">
        <p class="text-xs font-mono font-medium tracking-widest text-muted-foreground uppercase mb-8">All articles</p>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
          {rest.map((post) => (
            <div class="group relative flex flex-col border border-border rounded-lg p-5 hover:border-foreground/30 hover:shadow-sm transition-all bg-card">
              <a href={`/blog/${post.slug}`} class="absolute inset-0 rounded-lg z-0" aria-label={post.data.title}></a>
              <div class="relative z-10 flex flex-wrap gap-1.5 mb-4">
                {post.data.tags.slice(0, 2).map((tag) => (
                  <a
                    href={`/tag/${tag.toLowerCase().replace(/[\s\/]+/g, '-')}`}
                    class="inline-block whitespace-nowrap px-2.5 py-1 rounded-full text-xs font-medium leading-none bg-secondary text-secondary-foreground border border-border hover:border-foreground/40 transition-colors"
                  >
                    {tag}
                  </a>
                ))}
              </div>
              <h3 class="relative z-0 font-semibold text-foreground text-base leading-snug mb-2.5 group-hover:text-muted-foreground transition-colors line-clamp-2">
                {post.data.title}
              </h3>
              <p class="text-sm text-muted-foreground leading-relaxed mb-4 line-clamp-3 flex-1">
                {post.data.description}
              </p>
              <div class="flex items-center justify-between mt-auto pt-4 border-t border-border/60">
                <time class="text-xs text-muted-foreground" datetime={post.data.pubDate.toISOString()}>
                  {formatDate(post.data.pubDate)}
                </time>
                {post.data.readingTime && (
                  <span class="text-xs text-muted-foreground">{post.data.readingTime}</span>
                )}
              </div>
            </div>
          ))}
        </div>
      </section>
    )}

  </div>
</Base>
