---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  const tagSet = new Set(posts.flatMap((p) => p.data.tags));
  return [...tagSet].map((tag) => ({
    params: { tag: tag.toLowerCase().replace(/[\s\/]+/g, '-') },
    props: { tag },
  }));
}

interface Props { tag: string; }
const { tag } = Astro.props;

const allPosts = await getCollection('blog');
const posts = allPosts
  .filter((p) => p.data.tags.includes(tag))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const formatDate = (date: Date) =>
  new Intl.DateTimeFormat('en-US', { year: 'numeric', month: 'short', day: 'numeric' }).format(date);
---

<Base
  title={`#${tag} — mdspec blog`}
  description={`Articles tagged with ${tag} on mdspec blog.`}
>
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-16">

    <div class="mb-10">
      <a
        href="/"
        class="inline-flex items-center gap-1.5 text-sm text-muted-foreground hover:text-foreground transition-colors mb-8 group"
      >
        <svg class="w-3.5 h-3.5 transition-transform group-hover:-translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
        </svg>
        All articles
      </a>
      <p class="text-xs font-mono font-medium tracking-widest text-muted-foreground uppercase mb-3">Tag</p>
      <h1 class="text-3xl sm:text-4xl font-bold tracking-tight text-foreground mb-2">{tag}</h1>
      <p class="text-muted-foreground">{posts.length} article{posts.length !== 1 ? 's' : ''}</p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {posts.map((post) => (
        <div class="group relative flex flex-col border border-border rounded-lg p-5 hover:border-foreground/30 hover:shadow-sm transition-all bg-card">
          <a href={`/blog/${post.slug}`} class="absolute inset-0 rounded-lg z-0" aria-label={post.data.title}></a>
          <div class="relative z-10 flex flex-wrap gap-1.5 mb-4">
            {post.data.tags.slice(0, 2).map((t) => (
              <a
                href={`/tag/${t.toLowerCase().replace(/[\s\/]+/g, '-')}`}
                class={`inline-block whitespace-nowrap px-2.5 py-1 rounded-full text-xs font-medium leading-none border ${t === tag ? 'bg-foreground text-background border-foreground' : 'bg-secondary text-secondary-foreground border-border hover:border-foreground/40'} transition-colors`}
              >
                {t}
              </a>
            ))}
          </div>
          <h3 class="font-semibold text-foreground text-base leading-snug mb-2.5 group-hover:text-muted-foreground transition-colors line-clamp-2">
            {post.data.title}
          </h3>
          <p class="text-sm text-muted-foreground leading-relaxed mb-4 line-clamp-3 flex-1">
            {post.data.description}
          </p>
          <div class="flex items-center justify-between mt-auto pt-4 border-t border-border/60">
            <time class="text-xs text-muted-foreground" datetime={post.data.pubDate.toISOString()}>
              {formatDate(post.data.pubDate)}
            </time>
            {post.data.readingTime && (
              <span class="text-xs text-muted-foreground">{post.data.readingTime}</span>
            )}
          </div>
        </div>
      ))}
    </div>

  </div>
</Base>
